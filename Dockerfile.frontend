# ===== Frontend Dockerfile (Next.js) =====
FROM node:22-alpine AS builder
WORKDIR /app
COPY package.json bun.lock* ./
RUN npm install --legacy-peer-deps
COPY . .
RUN npm run build

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app ./
EXPOSE 3000
CMD ["npm", "start"]
