# 10s Only - Frontend Environment Variables
# Copy this file to .env.production and fill in the values for deployment

# API Configuration
# Change this to your Railway backend URL in production
NEXT_PUBLIC_API_URL=https://your-railway-backend-url.railway.app

# Razorpay Configuration
# Use your live Razorpay key ID (public, safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID

# Feature Flags
# Set to false in production to use live APIs
NEXT_PUBLIC_USE_MOCK=false

# Optional: Analytics and Monitoring
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Development only - not used in production
# NEXT_PUBLIC_DEBUG_MODE=false
