# ============================================
# 10s Only — Environment Variables (Frontend)
# ============================================
# When NEXT_PUBLIC_API_URL is NOT set, frontend runs in MOCK mode (demo data).
# When SET, frontend talks to the real Spring Boot backend.

# Backend API URL (uncomment to use real backend)
# NEXT_PUBLIC_API_URL=http://localhost:8080

# Supabase public credentials for frontend auth
# Create a Supabase project, then set these values in your local env.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Razorpay public key (safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_T5YWNXqJOQgqIN

# Backend secrets should be kept in backend/.env only.
# RAZORPAY_KEY_SECRET must never be exposed to frontend or committed to git.
# RAZORPAY_KEY_ID can be reused in frontend-specific env files.

# Copy backend/.env.example → backend/.env and fill in your Razorpay & MongoDB secrets.
# Do not commit backend/.env.

# Backend Razorpay credentials (keep secret, do not commit)
# RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
# RAZORPAY_KEY_SECRET=your-razorpay-secret
