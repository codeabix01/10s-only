# Backend environment variables for Spring Boot
# Copy this file to backend/.env and keep the copied file secret.

# Razorpay credentials (set your own values)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=your-razorpay-secret

# JWT and OTP config
APP_JWT_SECRET=your-secure-jwt-secret-min-256-bits-long
APP_OTP_PROVIDER=console

# MongoDB Atlas URI
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tensonly?retryWrites=true&w=majority&appName=Cluster0
