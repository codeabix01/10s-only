# 10s Only - Backend Environment Variables
# For Railway deployment, set these as environment secrets

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tensonly?retryWrites=true&w=majority&appName=Cluster0

# JWT Configuration
# IMPORTANT: Use a strong, random secret (min 256 bits = 32 characters for HS256)
# Generate with: openssl rand -base64 32
APP_JWT_SECRET=your-secure-jwt-secret-min-256-bits-long-change-this

# Razorpay Configuration
# Live credentials for production
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=your-razorpay-secret-key

# CORS Configuration
# Comma-separated list of allowed origins (Vercel frontend URL)
# Example: https://yourdomain.vercel.app,https://www.yourdomain.com
APP_CORS_ALLOWED_ORIGINS=https://your-vercel-frontend-url.vercel.app

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/

# Logging
LOGGING_LEVEL_COM_TENSONLY=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=INFO

# Optional: Database configuration
SPRING_DATA_MONGODB_AUTO_INDEX_CREATION=true

# Optional: Application profile (dev, prod, test)
SPRING_PROFILES_ACTIVE=prod
